{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "strict": false,
    "strictNullChecks": false,
    "skipLibCheck": true,
    "types": ["chrome", "node"]
  },
  "include": ["common.js", "content.js", "background.js", "popup.js", "options.js", "test/**/*.js", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
